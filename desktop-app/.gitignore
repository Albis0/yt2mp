# See https://help.github.com/articles/ignoring-files/ for more about ignoring files.

# dependencies
/node_modules
/.pnp
.pnp.*
.yarn/*
!.yarn/patches
!.yarn/plugins
!.yarn/releases
!.yarn/versions

# testing
/coverage

# next.js
/.next/
/out/

# production
/build

# misc
.DS_Store
*.pem

# debug
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.pnpm-debug.log*

# env files (can opt-in for committing if needed)
.env*

# vercel
.vercel

# typescript
*.tsbuildinfo
next-env.d.ts

# electron-builder output (200MB+ installers, regenerated by `bun run electron:build`)
/release

# bundled binaries — too large for git (yt-dlp ~18MB, ffmpeg ~100MB).
# Downloaded separately into resources/; see README for where to get them.
/resources/*.exe

#ideas
ideas.md